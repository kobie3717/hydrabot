# ── Telegram ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
ALLOWED_USER_ID=your_telegram_user_id

# ── Claude ──────────────────────────────────────────────────
CLAUDE_CLI_PATH=/root/.local/bin/claude
CLAUDE_WORKING_DIR=/root
CLAUDE_TIMEOUT=300000

# ── Circus ──────────────────────────────────────────────────
CIRCUS_URL=http://localhost:6200

# ── Bot Identity ────────────────────────────────────────────
BOT_NAME=MyBot
BOT_ROLE=assistant

# ── Optional: Webhook mode ──────────────────────────────────
# WEBHOOK_URL=https://yourdomain.com/webhook/mybot
# WEBHOOK_PORT=7711

# ── Bot-Circus ──────────────────────────────────────────────
BOT_CIRCUS_DIR=/root/bot-circus
PERFORMERS_DIR=/root/bot-circus/performers
CIRCUS_BRIDGE_PATH=/root/circus-bridge.mjs

# ── Circus owner keys ────────────────────────────────────────
CIRCUS_OWNER_ID=admin
CIRCUS_OWNER_KEY=/root/.circus/owner.key
CIRCUS_IDENTITY_DIR=/root/.circus
CIRCUS_DB=/root/.circus/circus.db
