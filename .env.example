# HydraBot Stack — Root Environment
# Copy to .env and fill in your values

# ── Claude ──────────────────────────────────────────────
# Path to the claude binary (run: which claude)
CLAUDE_CLI_PATH=claude

# ── Circus ──────────────────────────────────────────────
CIRCUS_URL=http://127.0.0.1:6200

# ── Optional: Telegram (for worker job notifications) ────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
