TELEGRAM_BOT_TOKEN=
ALLOWED_USER_ID=
BOT_NAME=AgentBot
# Path to python3 binary
PYTHON_PATH=python3
# Absolute path to hydrabot root (where agents/ lives)
# Defaults to auto-detect from bot.mjs location if not set
# HYDRABOT_DIR=/home/you/hydrabot
# Timeout for agent pack runs (ms) — redteam takes ~30s
AGENT_TIMEOUT=120000
