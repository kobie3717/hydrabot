# Required — get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Required — your Telegram user ID (get from @userinfobot)
ALLOWED_USER_ID=

# Bot display name
BOT_NAME=MyBot

# Path to claude binary (defaults to 'claude' in PATH)
CLAUDE_CLI_PATH=claude

# Working directory for Claude (defaults to cwd)
CLAUDE_WORKING_DIR=

# Claude response timeout in ms (default 120000 = 2 min)
CLAUDE_TIMEOUT=120000

# Path to personality file (default: SOUL.md in bot directory)
# SOUL_FILE=

# Circus API URL (default: localhost)
CIRCUS_URL=http://127.0.0.1:6200
