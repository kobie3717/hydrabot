TELEGRAM_BOT_TOKEN=your_bot_token_here
ALLOWED_USER_ID=your_telegram_user_id

CLAUDE_CLI_PATH=claude
CLAUDE_WORKING_DIR=/opt/hydrabot
CLAUDE_TIMEOUT=300000

CIRCUS_URL=http://localhost:6200
CIRCUS_DB=/root/.circus/circus.db
CIRCUS_OWNER_ID=admin

BOT_NAME=MyBot
BOT_ROLE=assistant

# Webhook mode (optional — comment out to use long polling)
# WEBHOOK_URL=https://yourdomain.com/webhook/mybot
# WEBHOOK_PORT=7711
