# Telegram bot token (from @BotFather) — used to notify on job completion
TELEGRAM_BOT_TOKEN=

# Your Telegram user ID — worker sends job results here
TELEGRAM_CHAT_ID=

# Path to claude binary (defaults to 'claude' in PATH)
CLAUDE_CLI_PATH=claude

# Working directory for Claude during jobs (defaults to $HOME)
CLAUDE_WORKING_DIR=/home/youruser
